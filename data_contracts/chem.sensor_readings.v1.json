{
  "title": "chem.sensor_readings.v1",
  "type": "object",
  "required": [
    "event_id",
    "event_ts",
    "equipment_id",
    "sensor_id",
    "metric_name",
    "metric_value",
    "metric_unit",
    "quality_flag"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "description": "Unique identifier of the event"
    },
    "event_ts": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the measurement occurred"
    },
    "ingestion_ts": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the event entered the platform"
    },
    "source_system": {
      "type": "string",
      "description": "Originating system or device"
    },
    "equipment_id": {
      "type": "string",
      "description": "Equipment identifier"
    },
    "sensor_id": {
      "type": "string",
      "description": "Sensor identifier"
    },
    "batch_id": {
      "type": ["string", "null"],
      "description": "Associated production batch"
    },
    "metric_name": {
      "type": "string",
      "description": "Measured metric name (temperature, pressure, pH, etc.)"
    },
    "metric_value": {
      "type": "number",
      "description": "Numeric measurement value"
    },
    "metric_unit": {
      "type": "string",
      "description": "Measurement unit"
    },
    "quality_flag": {
      "type": "string",
      "enum": ["OK", "WARN", "BAD"],
      "description": "Quality assessment of measurement"
    }
  }
}