{
  "title": "chem.lab_results.v1",
  "type": "object",
  "required": [
    "event_id",
    "event_ts",
    "sample_id",
    "test_code",
    "result_value",
    "result_unit",
    "result_status"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "event_ts": {
      "type": "string",
      "format": "date-time"
    },
    "ingestion_ts": {
      "type": "string",
      "format": "date-time"
    },
    "sample_id": {
      "type": "string",
      "description": "Laboratory sample identifier"
    },
    "batch_id": {
      "type": ["string", "null"]
    },
    "lab_id": {
      "type": "string",
      "description": "Laboratory performing the test"
    },
    "test_code": {
      "type": "string",
      "description": "Analytical test code"
    },
    "result_value": {
      "type": "number",
      "description": "Measured result value"
    },
    "result_unit": {
      "type": "string",
      "description": "Unit of measurement"
    },
    "method_code": {
      "type": "string",
      "description": "Analytical method used"
    },
    "analyst_id": {
      "type": "string",
      "description": "Identifier of analyst"
    },
    "result_status": {
      "type": "string",
      "enum": ["APPROVED", "REJECTED", "PENDING"]
    },
    "quality_flag": {
      "type": "string",
      "enum": ["OK", "WARN", "BAD"]
    }
  }
}